{
  "name": "frontend",
  "private": true,
  "version": "0.0.1",
  "description": "This is an example boilerplate for a multi-platform application using React, Vite, Electron, and Capacitor.",
  "author": {
    "name": "Navdeep Singh",
    "email": "navdeeps120@gmail.com"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently -k \"vite\" \"npm run dev:electron:only\"",
    "dev:electron:only": "wait-on tcp:5173 && cross-env NODE_ENV=development VITE_DEV_SERVER_URL=http://localhost:5173 nodemon --watch electron --ext cjs,json --exec \"electron .\"",
    "sync:android:dev": "wait-on tcp:5173 && npx cap sync android && npx cap open android",
    "dev:android": "concurrently -k \"vite\" \"npm run sync:android:dev\"",
    "build:web": "vite build",
    "build:android": "vite build --mode capacitor && npx cap sync android",
    "generate:assets": "npx @capacitor/assets generate --android --iconBackgroundColor=#ffffff --iconBackgroundColorDark=#111111",
    "build:windows": "vite build --mode electron && electron-builder --win",
    "build:mobile": "vite build --mode capacitor",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.1",
    "electron-builder": "22.14.13",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "nodemon": "^3.1.14",
    "vite": "^8.0.4",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.example.app",
    "productName": "Example App",
    "directories": {
      "output": "windows-build"
    },
    "files": [
      "dist/**",
      "electron/**"
    ],
    "icon": "electron/assets/app-icon.png",
    "npmRebuild": false,
    "win": {
      "target": "nsis",
      "icon": "electron/assets/app-icon.ico",
      "certificateSubjectName": "Example App"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "allowElevation": true,
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "allowToChangeInstallationDirectory": false,
      "guid": "app GUID- replace-with-actual-guid -- generate with uuidgen or similar tool"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://updates.invalid/satosangyo"
      }
    ]
  }
}
